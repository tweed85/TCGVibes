# Cloud replay aggregation — Supabase project credentials.
#
# Copy to .env.local (gitignored) and fill in with values from your
# Supabase project's "Project Settings → API" panel.
#
# Without these, the cloud-upload toggle in the Game menu will short-circuit
# with a "not configured" reason — no crash, no upload. Local replay
# history (Phase B) works without these vars.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
